{
  "test_cases": [
    {
      "name": "测试无效任务类型",
      "type": "process_task_add",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_node": {
                "node_type": "Module",
                "input_data": {
                  "input1": {
                    "md5": "abcd1234"
                  }
                },
                "output_data": {
                  "output1": {
                    "md5": "efgh5678"
                  }
                }
              }
            }
          },
          "Bench": {
            "node": {
              "bench_node": {
                "node_type": "Module",
                "input_data": {
                  "input1": {
                    "md5": "abcd1234"
                  }
                },
                "output_data": {
                  "output1": {
                    "md5": "efgh5678"
                  }
                }
              }
            }
          }
        },
        "npu_node_name": "npu_node",
        "bench_node_name": "bench_node",
        "task": "invalid_task"
      },
      "expected": {
        "success": false,
        "error": "task类型错误"
      }
    },
    {
