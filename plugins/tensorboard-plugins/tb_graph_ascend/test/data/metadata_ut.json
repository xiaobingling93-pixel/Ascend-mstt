        "npu_node_name": "npu_node",
        "bench_node_name": "bench_node",
        "task": "summary"
      },
      "expected": {
        "success": true
      }
    },
    {
      "name": "测试无效任务类型",
      "type": "process_task_delete",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_node": {
                "node_type": "Module",
                "matched_node_link": [
                  "bench_node"
                ],
                "data": {
                  "precision_index": 0.95
                }
              }
            }
          },
          "Bench": {
            "node": {
              "bench_node": {
                "node_type": "Module",
                "matched_node_link": [
                  "npu_node"
                ]
              }
            }
          }
        },
        "npu_node_name": "npu_node",
        "bench_node_name": "bench_node",
        "task": "invalid_task"
      },
      "expected": {
        "success": false,
        "error": "task类型错误"
      }
    },
    {
