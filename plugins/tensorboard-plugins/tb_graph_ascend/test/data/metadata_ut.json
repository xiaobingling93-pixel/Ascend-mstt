                  "input1": {
                    "Max": 1.0,
                    "Min": 0.1,
                    "Mean": 0.5,
                    "Norm": 0.7
                  },
                  "input2": {
                    "Max": 1.0,
                    "Min": 0.1,
                    "Mean": 0.5,
                    "Norm": 0.7
                  }
                },
                "output_data": {
                  "output1": {
                    "Max": 2.0,
