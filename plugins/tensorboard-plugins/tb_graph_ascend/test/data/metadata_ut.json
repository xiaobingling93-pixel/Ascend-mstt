{
  "test_cases": [
    {
      "name": "invalid_task_type_handling",
      "type": "process_task_add",
      "input": {
        "graph_data": {
          "NPU": { "node": { "npu_node": { "node_type": "Module" } } },
          "Bench": { "node": { "bench_node": { "node_type": "Module" } } }
        },
        "npu_node_name": "npu_node",
        "bench_node_name": "bench_node",
        "task": "invalid_task"
      },
      "expected": {
        "success": false,
        "error": "参数错误"
      }
    },
    {
      "name": "asymmetric_children_matching",
      "type": "process_task_add_child_layer",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_parent": {
                "node_type": "Module",
                "subnodes": ["npu_child1", "npu_child2"],
                "input_data": {
                  "npu_parent.data": { "md5": "123" }
                }
              },
              "npu_child1": { "node_type": "API" },
              "npu_child2": { "node_type": "API" }
            }
          },
          "Bench": {
            "node": {
              "bench_parent": {
                "node_type": "Module",
                "subnodes": ["bench_child1"],
                "input_data": {
                  "bench_parent.data": { "md5": "123" }
                }
              },
              "bench_child1": { "node_type": "API" }
            }
          }
        },
        "npu_node_name": "npu_parent",
        "bench_node_name": "bench_parent",
        "task": "md5"
      },
      "expected": {
        "success": true,
        "data": {
          "npuMatchNodes": {
            "npu_parent": "bench_parent",
            "npu_child1": "bench_child1"
          }
        }
      }
    },
    {
      "name": "config_batch_matching_validation",
      "type": "process_task_add_child_layer_by_config",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_layer1": { "node_type": "Module", "subnodes": ["npu_sub1"] },
              "npu_sub1": { "node_type": "API" }
            }
          },
          "Bench": {
            "node": {
              "bench_layer1": {
                "node_type": "Module",
                "subnodes": ["bench_sub1"]
              },
              "bench_sub1": { "node_type": "API" }
            }
          }
        },
        "match_node_links": { "npu_layer1": "bench_layer1" },
        "task": "md5"
      },
      "expected": {
        "success": true,
        "data": {
          "matchReslut": [true],
          "npuMatchNodes": {
            "npu_layer1": "bench_layer1",
            "npu_sub1": "bench_sub1"
          }
        }
      }
    },
    {
      "name": "duplicate_matching_cleanup",
      "type": "process_task_add",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_dup": {
                "node_type": "Module",
                "matched_node_link": ["old_bench_node"],
                "data": { "precision_index": 0.5 }
              }
            }
          },
          "Bench": {
            "node": {
              "bench_dup": {
                "node_type": "Module",
                "matched_node_link": ["old_npu_node"]
              }
            }
          }
        },
        "npu_node_name": "npu_dup",
        "bench_node_name": "bench_dup",
        "task": "md5"
      },
      "expected": {
        "success": true,
        "data": {
          "npuUnMatchNodes": [],
          "benchUnMatchNodes": []
        }
      }
    },
    {
      "name": "deep_recursive_unmatching",
      "type": "process_task_delete_child_layer",
      "input": {
        "graph_data": {
          "NPU": {
            "node": {
              "npu_root": {
                "node_type": "Module",
                "subnodes": ["npu_l1"],
                "matched_node_link": ["bench_root"]
              },
              "npu_l1": {
                "node_type": "Module",
                "subnodes": ["npu_l2"],
                "matched_node_link": ["bench_l1"]
              },
              "npu_l2": {
                "node_type": "API",
                "matched_node_link": ["bench_l2"]
              }
            }
          },
          "Bench": {
            "node": {
              "bench_root": {
                "node_type": "Module",
                "subnodes": ["bench_l1"],
                "matched_node_link": ["npu_root"]
              },
              "bench_l1": {
                "node_type": "Module",
                "subnodes": ["bench_l2"],
                "matched_node_link": ["npu_l1"]
              },
              "bench_l2": {
                "node_type": "API",
                "matched_node_link": ["npu_l2"]
              }
            }
          }
        },
        "npu_node_name": "npu_root",
        "bench_node_name": "bench_root",
        "task": "md5"
      },
      "expected": {
        "success": true,
        "data": {
          "npuUnMatchNodes": ["npu_root", "npu_l1", "npu_l2"],
          "benchUnMatchNodes": ["bench_root", "bench_l1", "bench_l2"]
        }
      }
    }
  ]
}
