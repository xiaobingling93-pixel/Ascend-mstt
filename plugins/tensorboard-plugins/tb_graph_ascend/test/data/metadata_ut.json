                    "Mean": 1.0,
                    "Norm": 1.4
                  },
                  "output2": {
                    "Max": 2.0,
                    "Min": 0.2,
                    "Mean": 1.0,
                    "Norm": 1.4
                  }
                },
                "matched_node_link": []
              }
            }
          },
          "Bench": {
            "node": {
              "bench_node": {
                "node_type": "Module",
                "matched_node_link": []
              }
            }
          }
